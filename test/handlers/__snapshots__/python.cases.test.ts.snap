`;

exports[`compress - python > pytest - all green: collapses full session to one "Pytest: N passed" line 1`] = `"Pytest: 42 passed"`;

exports[`compress - python > pytest - empty output passes through as empty (edge case) 1`] = `""`;

exports[`compress - python > pytest - failures: header with passed/failed/error(s) counts + FAIL/ERR list, traceback stripped 1`] = `
"Pytest: 5 passed, 2 failed, 1 error(s)
  FAIL: tests/test_math.py::test_divide
  FAIL: tests/test_str.py::test_upper
  FAIL: ERR:tests/test_broken_import.py"
`;

exports[`compress - python > ruff check - clean run: returns the "All checks passed" line 1`] = `"All checks passed!"`;

exports[`compress - python > ruff check - one summary line: total issues, file count, top rules; messages dropped 1`] = `"ruff: 6 issue(s) in 3 file(s)  F401(2) E501(2) F811(1) E722(1)"`;

exports[`compress - python > ruff format - collapses per-file lines to one reformatted/unchanged tally 1`] = `"ruff format: 3 reformatted, 2 unchanged"`;
