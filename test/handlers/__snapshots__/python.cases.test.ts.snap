// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`compress - python > go test - all pass: collapses to the single ok package line 1`] = `"ok  	example.com/mymath	0.008s"`;

exports[`compress - python > go test - failures: summary header + FAIL names, RUN/detail lines stripped 1`] = `
"Go test: 3 passed, 2 failed
  FAIL: TestDivide (0.00s)
  FAIL: TestModulo (0.01s)"
`;

exports[`compress - python > mypy - clean run: returns the Success line only 1`] = `"Success: no issues found in 12 source files"`;

exports[`compress - python > mypy - groups errors by file, summary header with top codes, note: lines stripped 1`] = `
"mypy: 5 error(s) in 3 file(s)  return-value(1) arg-type(1) return(1) name-defined(1) no-untyped-def(1)
src/models.py (2)
  Incompatible return value type (got "int", expected "str")  [return-value]
  Argument 1 to "save" has incompatible type "None"; expected "User"  [arg-type]
src/views.py (2)
  Missing return statement  [return]
  Name "reqeust" is not defined  [name-defined]
src/utils.py (1)
  Function is missing a return type annotation  [no-untyped-def]"
`;

exports[`compress - python > pip install - strips Collecting/Downloading/Using cached/Looking-in noise, keeps result 1`] = `
"Installing collected packages: urllib3, charset-normalizer, certifi, requests
Successfully installed certifi-2023.7.22 charset-normalizer-3.2.0 requests-2.31.0 urllib3-2.0.4"
`;

exports[`compress - python > pip list --outdated - one "pkg (old → new)" row each, header + Type column dropped 1`] = `
"pip outdated:
  certifi (2023.7.22 → 2024.2.2)
  pip (23.1.2 → 24.0)
  requests (2.28.0 → 2.31.0)
  setuptools (67.8.0 → 69.5.1)
