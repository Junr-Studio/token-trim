// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`compress - source > cat Cargo.toml - emits [toml sections] header + truncates past 30 lines 1`] = `
"[toml - sections: [package], [dependencies], [dev-dependencies], [build-dependencies], [features], [profile.release], [[bin]]]
[package]
name = "my-crate"
version = "0.4.2"
edition = "2021"
license = "MIT"

[dependencies]
serde = { version = "1.0", features = ["derive"] }
serde_json = "1.0"
tokio = { version = "1.35", features = ["full"] }
anyhow = "1.0"
thiserror = "1.0"
clap = { version = "4.4", features = ["derive"] }
tracing = "0.1"
tracing-subscriber = "0.3"
reqwest = { version = "0.11", features = ["json"] }
hyper = "0.14"
tower = "0.4"
futures = "0.3"
bytes = "1.5"
uuid = { version = "1.6", features = ["v4"] }
chrono = { version = "0.4", features = ["serde"] }
regex = "1.10"
once_cell = "1.19"
rand = "0.8"
base64 = "0.21"
sha2 = "0.10"
hex = "0.4"

[dev-dependencies]
... +29 more lines"
`;

