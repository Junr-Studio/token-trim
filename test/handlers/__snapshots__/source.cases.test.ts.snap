exports[`compress - source > cat deploy.sh - strips # comments but keeps bodies (no brace collapse for shell) 1`] = `
"set -euo pipefail

npm run build

deploy() {
  echo "Deploying..."
  scp -r dist/ server:/var/www
}

deploy"
`;

exports[`compress - source > cat empty.ts - empty input yields empty output 1`] = `""`;

exports[`compress - source > cat notes.txt - unknown extension passes through; comment-like lines preserved 1`] = `
"TODO list for the release:
// this looks like a comment but is plain text
# so does this line
- ship the thing
- write the changelog"
`;

